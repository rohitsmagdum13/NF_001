# Copy to `.env` and fill in real values. Never commit `.env`.

# --- AWS Bedrock (primary LLM provider) ---
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
BEDROCK_REGION=ap-southeast-2

# --- OpenAI (fallback LLM provider) ---
OPENAI_API_KEY=

# --- Optional: IMAP polling for Lolex PDFs ---
IMAP_HOST=
IMAP_USER=
IMAP_PASSWORD=
IMAP_FOLDER=INBOX

# --- Optional: Horizon CMS publish target ---
HORIZON_API_URL=
HORIZON_API_TOKEN=

# --- Optional: SMTP for email digest ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# --- Runtime ---
LOG_LEVEL=INFO
